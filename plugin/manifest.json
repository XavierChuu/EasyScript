{
  "id": "com.easyscript.app",
  "name": "EasyScript",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.0"
    }
  ],
  "manifestVersion": 6,
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": {
        "default": "EasyScript"
      },
      "minimumSize": {
        "width": 300,
        "height": 400
      },
      "maximumSize": {
        "width": 600,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 700
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["toolbar"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["toolbar"]
        }
      ]
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["http://localhost", "https://api.anthropic.com"]
    },
    "localFileSystem": "fullAccess",
    "clipboard": "readAndWrite"
  }
}
